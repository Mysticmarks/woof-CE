#!/bin/sh

rm -rf etc

#slackware
if [ -f bin/mktemp-gnu ] ; then
	mv bin/mktemp-gnu bin/mktemp
fi

[ "$DISTRO_BINARY_COMPAT" = "void" ] && mv -f usr/bin ./bin

#260324 for ubuntu with Rust coreutils-from-uutils
[ -d usr/lib/cargo/bin/coreutils ] && mv -f usr/lib/cargo/bin/coreutils/* usr/bin

#delete invalid symlinks
find -L . -type l -delete
