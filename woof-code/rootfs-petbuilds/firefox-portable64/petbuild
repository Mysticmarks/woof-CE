ffver=140.5.0esr

download() {
    [ -f firefox-${ffver}.tar.bz2 ] || wget -t 3 -T 60 https://ftp.mozilla.org/pub/firefox/releases/${ffver}/linux-x86_64/en-US/firefox-${ffver}.tar.xz
}

build() {
    mkdir -p /opt/FirefoxESR-portable64
    tar -xJf firefox-${ffver}.tar.xz -C /opt/FirefoxESR-portable64
    mv /opt/FirefoxESR-portable64/firefox{,64}
}
